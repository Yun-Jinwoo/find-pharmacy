# 약국 어디가 — 필요한 환경변수
# 로컬: 이 파일을 .env.local 로 복사해 값을 채운다 (cp .env.example .env.local)
# 배포(Vercel): Settings → Environment Variables 에 아래 키를 등록

# 공공데이터포털 약국 정보 API 서비스 키 (서버 전용 — 브라우저에 노출되지 않음)
# 발급: https://www.data.go.kr  (국립중앙의료원 ErmctInsttInfoInqireService)
PHARMACY_API_KEY=

# 카카오맵 JavaScript 키 (클라이언트 노출 — NEXT_PUBLIC_ 접두어)
# 발급: https://developers.kakao.com  (내 애플리케이션 → 앱 키 → JavaScript 키)
# ⚠️ 배포 후 Kakao Developers → 플랫폼 → Web 에 배포 도메인(예: xxx.vercel.app)을 등록해야 지도가 뜬다
NEXT_PUBLIC_KAKAO_MAP_KEY=
